# Copy this file to .env and fill in your values
# .env is gitignored — never commit real keys

TORN_API_KEY=your_torn_api_key_here

# --- Commentary LLM (commentary_worker.py) ---
# Without any key the worker runs in dry-run mode (prints prompts only).
SARVAM_API_KEY=your_sarvam_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- Discord output (discord_notify.py) ---
# Option A (simplest): a channel webhook URL — no bot needed.
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy
# Option B: post as a bot. Needs the bot invited to the server with Send Messages,
# plus the target channel's ID (enable Developer Mode → right-click channel → Copy ID).
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_CHANNEL_ID=your_channel_id_here
